# Apache configuration for cPanel PHP Backend Router
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Do not rewrite if the request points to an actual file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite all other paths (like /api/status or /jellyfin/Users) to index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
